{
  "appId": "com.example.nouture",
  "appName": "Nouture",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#FF2937",
      "showSpinner": false,
      "spinnerColor": "#ffffff",
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#FF2937"
    }
  }
}